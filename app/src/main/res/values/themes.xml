<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Host app theme (MainActivity) -->
    <style name="Theme.SpiningWheel" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
      SpinActivity theme — full-screen, edge-to-edge, no title bar.
      The activity draws its own background (dark scrim + wheel assets).
    -->
    <style name="Theme.SpinWheel.FullScreen" parent="Theme.SpiningWheel">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

</resources>
