<?xml version="1.0" encoding="utf-8"?>
<!--
  Home screen widget layout for the Spin Wheel.

  Layer order (back → front):
  1. widget_bg       – full-bleed background image
  2. widget_wheel    – spinning wheel, centered (rotated via Matrix on tap)
  3. widget_frame    – static frame overlay, centered
  4. widget_spin_btn – tappable spin button, centered on top

  All bitmaps are set programmatically via RemoteViews.setImageViewBitmap().
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Layer 1: Background -->
    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@string/widget_bg_desc" />

    <!-- Layer 2: Wheel (rotated bitmap on spin) -->
    <ImageView
        android:id="@+id/widget_wheel"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center"
        android:scaleType="fitCenter"
        android:contentDescription="@string/widget_wheel_desc" />

    <!-- Layer 3: Static frame overlay -->
    <ImageView
        android:id="@+id/widget_frame"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="center"
        android:scaleType="fitCenter"
        android:contentDescription="@string/widget_frame_desc" />

    <!-- Layer 4: Spin button (clickable) -->
    <ImageView
        android:id="@+id/widget_spin_btn"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/widget_spin_desc" />

</FrameLayout>
