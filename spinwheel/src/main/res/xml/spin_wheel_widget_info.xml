<?xml version="1.0" encoding="utf-8"?>
<!--
  AppWidget provider metadata.
  minWidth/minHeight → roughly 3×3 cells (each cell ~74dp on phone).
  updatePeriodMillis → 43200000 ms = 12 hours.
                       The system calls onUpdate() every 12 h to refresh
                       Firebase Remote Config + re-download changed assets.
                       Minimum allowed by Android is 1800000 ms (30 min).
-->
<appwidget-provider
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="250dp"
    android:updatePeriodMillis="43200000"
    android:initialLayout="@layout/widget_spin_wheel"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/spin_wheel_widget_description" />
